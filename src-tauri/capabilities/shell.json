{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "shell",
  "description": "shell 相关权限",
  "windows": [
    "main"
  ],
  "permissions": [
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "xattr-d-apple",
          "cmd": "xattr",
          "args": [
            "-d",
            "com.apple.quarantine",
            {
              "validator": ".*"
            }
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": [
            "**"
          ],
          "cmd": "",
          "name": "binaries/ffmpeg",
          "sidecar": true
        }
      ]
    }
  ]
}