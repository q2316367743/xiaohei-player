{
  "$schema": "./node_modules/utools-api-types/resource/utools.schema.json",
  "main": "dist/index.html",
  "preload": "index.js",
  "logo": "public/logo.png",
  "platform": [
    "win32",
    "darwin",
    "linux"
  ],
  "development": {
    "main": "http://localhost:5124/"
  },
  "pluginSetting": {
    "single": true,
    "height": 0
  },
  "tools" : {
    "list_library": {
      "description": "获取全部的媒体库",
      "inputSchema": { "type": "object", "additionalProperties": false },
      "outputSchema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "description": "媒体库 ID" },
            "name": { "type": "string", "description": "媒体库名字" }
          },
          "required": ["id", "name"]
        }
      }
    },
    "page_video": {
      "description": "根据媒体库 ID 分页获取视频",
      "inputSchema": {
        "type": "object",
        "properties": {
          "pageNum": { "type": "number", "description": "页码" },
          "pageSize": { "type": "number", "description": "每页大小" },
          "name": { "type": "string", "description": "支持模糊匹配的视频名字" },
          "library_id": { "type": "string", "description": "媒体库 ID" }
        },
        "required": ["pageNum", "pageSize", "library_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "library_id": { "type": "string" },
            "file_path": { "type": "string" },
            "file_name": { "type": "string" },
            "file_size": { "type": "number" },
            "file_birthtime": { "type": "number" },
            "screenshot_path": { "type": "string" },
            "sprite_path": { "type": "string" },
            "vtt_path": { "type": "string" },
            "cover_path": { "type": "string" },
            "duration_ms": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "fps": { "type": "number" },
            "bit_rate": { "type": "number" },
            "video_codec": { "type": "string" },
            "audio_codec": { "type": "string" },
            "container_format": { "type": "string" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "link": { "type": "string" },
            "release_date": { "type": "string" },
            "director": { "type": "string" },
            "studio_id": { "type": "string" },
            "last_played_at": { "type": "number" },
            "play_count": { "type": "number" },
            "resume_time": { "type": "number" },
            "is_deleted": { "type": "string" },
            "is_liked": { "type": "string" },
            "created_at": { "type": "number" },
            "updated_at": { "type": "number" }
          }
        }
      }
    },
    "list_actor": {
      "description": "根据媒体库获取全部的演员",
      "inputSchema": {
        "type": "object",
        "properties": {
          "library_id": { "type": "string", "description": "媒体库 ID" }
        },
        "required": ["library_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "library_id": { "type": "string" },
            "name": { "type": "string" },
            "original_name": { "type": "string" },
            "gender": { "type": "string", "enum": ["male", "female", "other"] },
            "birth_date": { "type": "string" },
            "death_date": { "type": "string" },
            "biography": { "type": "string" },
            "photo_path": { "type": "string" },
            "created_at": { "type": "number" },
            "updated_at": { "type": "number" }
          }
        }
      }
    },
    "list_tag": {
      "description": "根据媒体库获取全部的标签",
      "inputSchema": {
        "type": "object",
        "properties": {
          "library_id": { "type": "string", "description": "媒体库 ID" }
        },
        "required": ["library_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "library_id": { "type": "string" },
            "name": { "type": "string" },
            "color": { "type": "string" },
            "created_at": { "type": "number" },
            "updated_at": { "type": "number" }
          }
        }
      }
    },
    "add_library": {
      "description": "新增媒体库",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "媒体库名字" },
          "path": { "type": "string", "description": "媒体库路径" },
          "password": { "type": "string", "description": "密码（可选）" }
        },
        "required": ["name", "path"],
        "additionalProperties": false
      }
    },
    "scan_library": {
      "description": "扫描指定的媒体库",
      "inputSchema": {
        "type": "object",
        "properties": {
          "library_id": { "type": "string", "description": "媒体库 ID" }
        },
        "required": ["library_id"],
        "additionalProperties": false
      }
    },
    "scan_all_library": {
      "description": "扫描全部的媒体库",
      "inputSchema": { "type": "object", "additionalProperties": false }
    }
  },
  "features": [
    {
      "code": "launch",
      "explain": "小黑影音",
      "icon": "public/logo.png",
      "platform": [
        "win32",
        "darwin",
        "linux"
      ],
      "cmds": [
        "小黑影音"
      ]
    }
  ]
}